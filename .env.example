# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-django-insecure-key-generator
DEBUG=True
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1,ecome-finance-2.onrender.com
